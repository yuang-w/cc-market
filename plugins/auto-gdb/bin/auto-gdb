#!/usr/bin/env bash
set -e


# Detect architecture
ARCH=$(uname -m)
case "${ARCH}" in
  x86_64|amd64) BINARY="auto-gdb-linux-amd64" ;;
  aarch64|arm64) BINARY="auto-gdb-linux-arm64" ;;
  *) echo "Unsupported architecture: ${ARCH}" >&2; exit 1 ;;
esac

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY="${DIR}/${BINARY}"

exec "${BINARY}" "$@"